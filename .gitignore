# ============================================
# Tournament Platform - Project Specific .gitignore
# ============================================

# ----------------------------
# Node Modules (Backend)
# ----------------------------
server/node_modules/
server/package-lock.json

# ----------------------------
# Node Modules (Frontend)
# ----------------------------
client/node_modules/
client/package-lock.json

# ----------------------------
# Environment Variables
# ----------------------------
server/.env
client/.env
.env

# ----------------------------
# Firebase Service Account (CRITICAL - NEVER COMMIT!)
# ----------------------------
server/config/service-account-key.json
server/config/*.json
!server/config/.gitkeep

# ----------------------------
# Build Folders
# ----------------------------
client/build/
client/dist/
server/dist/

# ----------------------------
# Logs
# ----------------------------
*.log
server/logs/
client/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------
# IDE Files
# ----------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------
# OS Generated Files
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ----------------------------
# Temporary Files
# ----------------------------
*.tmp
*.temp
tmp/
temp/
server/temp/
client/temp/

# ----------------------------
# Backup Files
# ----------------------------
*.bak
*.backup
*.old
server/backups/
client/backups/

# ----------------------------
# Screenshots (if any in project)
# ----------------------------
*.png
*.jpg
*.jpeg
*.gif
*.bmp
screenshots/

# ----------------------------
# Testing
# ----------------------------
coverage/
test-results/
*.test.js.map

# ----------------------------
# Runtime Data
# ----------------------------
*.pid
*.seed
*.pid.lock

# ----------------------------
# Database files (if local)
# ----------------------------
*.db
*.sqlite
*.sqlite3

# ----------------------------
# Certificate files
# ----------------------------
*.pem
*.crt
*.key
*.p12

# ----------------------------
# Archive files
# ----------------------------
*.zip
*.rar
*.7z
*.tar
*.gz

# ----------------------------
# Docker (if used)
# ----------------------------
*.dockerignore
Dockerfile
docker-compose.override.yml

# ----------------------------
# React / Frontend Specific
# ----------------------------
client/.eslintcache
client/.env.local
client/.env.development.local
client/.env.test.local
client/.env.production.local
client/build/
client/service-worker.js
client/*.map

# ----------------------------
# Backend Specific
# ----------------------------
server/uploads/
server/temp-uploads/
server/*.map

# ----------------------------
# Documentation
# ----------------------------
docs/_build/
*.md.bak

# ----------------------------
# Package Manager Specific
# ----------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml
npm-shrinkwrap.json

# ----------------------------
# Misc
# ----------------------------
*.iml
.project
.classpath
.vscode/
.idea/
*.sublime-*